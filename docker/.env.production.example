# ─────────────────────────────────────────────────────────────
#  데이터 수집기 · Production(운영) 환경 설정 예시
#  · install.sh production 실행 시 이 파일이 docker/.env 로 복사됩니다.
#  · JWT_SECRET / ENCRYPTION_KEY 는 install.sh 가 자동 생성합니다.
#  · 나머지 빈 값(POSTGRES_PASSWORD, OPENAI_API_KEY 등)은 배포 전 반드시 채우세요.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL (운영: 외부/내부망의 기존 DB에 직접 접속. compose db 컨테이너 미사용) ──
POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DATABASE=
POSTGRES_USERNAME=
POSTGRES_PASSWORD=

# ── 파일 저장 경로 (컨테이너 내부 절대경로) ──
FILE_STORAGE_PATH=/app/storage/uploads

# ── 인증 ── (install.sh 자동 생성)
JWT_SECRET=
JWT_EXPIRE_MINUTES=60

# ── 대칭 암호화 키 (Fernet) ── (install.sh 자동 생성)
ENCRYPTION_KEY=

# ── LLM ──
LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_ENDPOINT=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-4o-mini

# 운영 LLM 키를 입력하세요.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
LLM_STUB_MODE=false
LLM_MAX_INPUT_TOKENS=28000

# ── 운영 ──
AUTO_MIGRATE=true
LOG_LEVEL=INFO

# ── 프론트엔드가 호출할 백엔드 API 베이스 ──
# 실제 서비스 도메인/호스트로 교체하세요. (예: https://collector.example.com/api/v1)
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
