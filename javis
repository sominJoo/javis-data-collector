#!/usr/bin/env bash
#
# 데이터 수집기 · 서버 제어 CLI
#   사용법:  ./javis {start | stop | status | restart}
#
#   backend(uvicorn) 와 frontend(Nuxt node 서버)를 백그라운드로 실행/관리한다.
#   실행에 필요한 경로는 install.sh 가 만든 .run/env.conf 에서 읽는다.
#
set -euo pipefail
cd "$(dirname "$0")"
ROOT="$(pwd)"
RUN_DIR="$ROOT/.run"

log() { printf '  %s\n' "$*"; }
ok()  { printf '\033[32m✓\033[0m %s\n' "$*"; }
err() { printf '\033[31m✗\033[0m %s\n' "$*" >&2; }

# ── 실행 환경 로드 ──────────────────────────────────────────
if [ ! -f "$RUN_DIR/env.conf" ]; then
  err "설치가 필요합니다. 먼저 ./install.sh 를 실행하세요. (.run/env.conf 없음)"
  exit 1
fi
# shellcheck disable=SC1091
. "$RUN_DIR/env.conf"

BACKEND_PID="$RUN_DIR/backend.pid"
FRONTEND_PID="$RUN_DIR/frontend.pid"
BACKEND_PORT="${BACKEND_PORT:-8000}"
FRONTEND_PORT="${FRONTEND_PORT:-3000}"

# ── 유틸 ────────────────────────────────────────────────────
is_running() {  # $1: pidfile
  [ -f "$1" ] || return 1
  local pid; pid="$(cat "$1" 2>/dev/null || echo '')"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

# 기동 직후 프로세스가 살아있는지 확인한다.
# 죽었으면 로그 마지막 부분을 출력하고 실패(1)를 반환한다.
STARTUP_WAIT="${STARTUP_WAIT:-3}"   # 기동 확인 대기 시간(초)
verify_started() {  # $1: pidfile  $2: 이름  $3: 로그파일
  sleep "$STARTUP_WAIT"
  if is_running "$1"; then
    return 0
  fi
  err "$2 기동 실패 (프로세스가 종료됨). 로그 마지막 30줄:"
  echo "──────────────────────────────────────────" >&2
  tail -n 30 "$3" >&2 2>/dev/null || true
  echo "──────────────────────────────────────────" >&2
  rm -f "$1" 2>/dev/null || true
  return 1
}

# ── start ───────────────────────────────────────────────────
start_backend() {
  if is_running "$BACKEND_PID"; then
    log "backend 이미 실행 중 (PID $(cat "$BACKEND_PID"))"; return
  fi
  [ -x "$UVICORN_BIN" ] || { err "uvicorn 실행 파일 없음: $UVICORN_BIN (install.sh 재실행 필요)"; return 1; }
  (
    cd "$ROOT/backend"
    nohup "$UVICORN_BIN" main:app --host 0.0.0.0 --port "$BACKEND_PORT" \
      > "$RUN_DIR/backend.log" 2>&1 &
    echo $! > "$BACKEND_PID"
  )
  verify_started "$BACKEND_PID" backend "$RUN_DIR/backend.log" || return 1
  ok "backend 시작 (PID $(cat "$BACKEND_PID"), http://localhost:${BACKEND_PORT})"
}

start_frontend() {
  if is_running "$FRONTEND_PID"; then
    log "frontend 이미 실행 중 (PID $(cat "$FRONTEND_PID"))"; return
  fi
  local server="$ROOT/frontend/.output/server/index.mjs"
  [ -f "$server" ] || { err "frontend 빌드 산출물 없음: $server (install.sh 재실행 필요)"; return 1; }
  (
    cd "$ROOT/frontend"
    # frontend/.env 의 값(NUXT_PUBLIC_API_BASE_URL 등)을 런타임 환경에 주입
    [ -f .env ] && { set -a; . ./.env; set +a; }
    export PORT="${PORT:-$FRONTEND_PORT}"
    nohup "$NODE_BIN" "$server" > "$RUN_DIR/frontend.log" 2>&1 &
    echo $! > "$FRONTEND_PID"
  )
  verify_started "$FRONTEND_PID" frontend "$RUN_DIR/frontend.log" || return 1
  ok "frontend 시작 (PID $(cat "$FRONTEND_PID"), http://localhost:${FRONTEND_PORT})"
}

# ── stop ────────────────────────────────────────────────────
stop_one() {  # $1: pidfile  $2: 이름
  if is_running "$1"; then
    local pid; pid="$(cat "$1")"
    kill "$pid" 2>/dev/null || true
    rm -f "$1"
    ok "$2 중지 (PID $pid)"
  else
    log "$2 실행 중 아님"
    rm -f "$1" 2>/dev/null || true
  fi
}

# ── status ──────────────────────────────────────────────────
status_one() {  # $1: pidfile  $2: 이름  $3: 포트
  if is_running "$1"; then
    printf '  %-9s \033[32mrunning\033[0m  (PID %s, :%s)\n' "$2" "$(cat "$1")" "$3"
  else
    printf '  %-9s \033[31mstopped\033[0m\n' "$2"
  fi
}

status_all() {
  echo "데이터 수집기 상태:"
  status_one "$BACKEND_PID"  backend  "$BACKEND_PORT"
  status_one "$FRONTEND_PID" frontend "$FRONTEND_PORT"
}

# ── 디스패치 ────────────────────────────────────────────────
mkdir -p "$RUN_DIR"
case "${1:-}" in
  start)
    rc=0
    start_backend  || rc=1
    start_frontend || rc=1
    echo
    status_all
    log "로그: tail -f .run/backend.log  |  tail -f .run/frontend.log"
    if [ "$rc" -ne 0 ]; then
      err "일부 서비스 기동에 실패했습니다. 위 로그를 확인하세요."
    fi
    exit "$rc"
    ;;
  stop)
    stop_one "$BACKEND_PID"  backend
    stop_one "$FRONTEND_PID" frontend
    ;;
  status)
    status_all
    ;;
  restart)
    stop_one "$BACKEND_PID"  backend
    stop_one "$FRONTEND_PID" frontend
    sleep 1
    rc=0
    start_backend  || rc=1
    start_frontend || rc=1
    echo
    status_all
    if [ "$rc" -ne 0 ]; then
      err "일부 서비스 기동에 실패했습니다. 위 로그를 확인하세요."
    fi
    exit "$rc"
    ;;
  *)
    echo "사용법: ./javis {start | stop | status | restart}"
    exit 1
    ;;
esac
