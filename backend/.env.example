POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=jarivs_data_collector
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=postgres

FILE_STORAGE_PATH=./storage/uploads

JWT_SECRET=change-me
JWT_EXPIRE_MINUTES=60

# Fernet 대칭키 (base64 32바이트). 생성: python -c "from app.core.crypto import generate_key; print(generate_key())"
ENCRYPTION_KEY=0RN-i-4NXKG9FiSyi7yY7GJrbVoBCsc7_Kq_GPxWxBY=

LLM_DEFAULT_PROVIDER=openai
LLM_DEFAULT_ENDPOINT=https://api.openai.com/v1
LLM_DEFAULT_MODEL=gpt-5-mini
OPENAI_API_KEY=

EMBEDDING_MODEL=text-embedding-3-small

# true면 외부 LLM 없이 결정적 placeholder로 분석 파이프라인 구동 (로컬/CI 검증용)
LLM_STUB_MODE=false

# LLM 요청당 허용할 최대 입력 토큰(모델 컨텍스트 한도보다 낮게). 큰 문서 요약/스킬 추출 시
# 컨텍스트 초과(400)를 막는 map-reduce 요약·원문 클리핑 기준. 모델 한도 32768이면 28000 권장.
LLM_MAX_INPUT_TOKENS=28000

# true면 앱 startup에서 운영 DB(collector_service) 마이그레이션 자동 실행 (alembic upgrade head)
AUTO_MIGRATE=true

# 로그 레벨 (DEBUG/INFO/WARNING/ERROR). 디버깅 시 DEBUG
LOG_LEVEL=INFO
